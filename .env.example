# ECP environment template — copy to .env and fill in.
# Every variable is optional; defaults are sensible for local docker compose.

# ----- Resolution engine -----
ECP_RESOLUTION_MODE=orchestrator           # "orchestrator" (default) or "intelligent"
ECP_LLM_PROVIDER=anthropic                 # "anthropic" or "openai"
ECP_LLM_MODEL=claude-haiku-4-5-20251001    # override to claude-sonnet-4-6 for harder reasoning

# ----- Embeddings (provider flexible) -----
ECP_EMBEDDING_PROVIDER=voyage              # "voyage" (default), "openai", or "none"
ECP_EMBEDDING_DIM=1024                     # 1024 for voyage-3-lite; 1536 for openai text-embedding-3-small
# ECP_EMBEDDING_MODEL=                     # leave unset to pick the provider default

# ----- API keys (optional, but enable real features) -----
ECP_ANTHROPIC_API_KEY=                     # for intelligent mode (intent parsing)
ECP_VOYAGE_API_KEY=                        # free at voyageai.com — no card required
ECP_OPENAI_API_KEY=                        # alternative embedding provider, pay-per-use

# ----- Infrastructure (docker compose defaults) -----
ECP_NEO4J_URI=bolt://localhost:7687
ECP_NEO4J_USER=neo4j
ECP_NEO4J_PASSWORD=ecp_local_dev
ECP_POSTGRES_DSN=postgresql://ecp:ecp_local_dev@localhost:5432/ecp
ECP_REDIS_URL=redis://localhost:6379

# ----- Governance -----
ECP_OPA_URL=http://localhost:8181
ECP_OPA_DEFAULT_ALLOW=false                # fail-closed by default; set true ONLY for the public demo
ECP_SEARCH_REQUIRE_IDENTITY=true           # anonymous search returns empty when true
ECP_API_KEY=                               # when set, all REST calls require x-ecp-api-key

# ----- Demo / public sandbox -----
ECP_DEMO_MODE=false                        # set true for public deployments — opens CORS, prints banner

# ----- Semantic layer (Cube.js REST) -----
ECP_CUBE_API_URL=                          # e.g. http://localhost:4000/cubejs-api/v1
ECP_CUBE_API_SECRET=
